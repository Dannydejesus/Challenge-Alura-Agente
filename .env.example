# Configuración del Agente RAG — Challenge Alura Agente
# IMPORTANTE: Nunca subir este archivo a GitHub
# Copia este archivo como .env y completa tus valores reales

# =============================================
# GOOGLE GEMINI API
# =============================================
GOOGLE_API_KEY=tu_api_key_aqui

# =============================================
# CONFIGURACIÓN DEL MODELO
# =============================================
LLM_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# =============================================
# BASE VECTORIAL
# =============================================
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=rh_documents

# =============================================
# PROCESAMIENTO DE DOCUMENTOS
# =============================================
DOCS_PATH=./docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_RETRIEVAL_DOCS=5

# =============================================
# INTERFAZ
# =============================================
APP_TITLE=Agente RH — TechCorp
APP_DESCRIPTION=Asistente de Recursos Humanos basado en documentos corporativos

# =============================================
# LOGS
# =============================================
LOG_LEVEL=INFO
LOG_PATH=./logs/agent.log
